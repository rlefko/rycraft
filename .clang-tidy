# Checks: bugprone-*,cppcoreguidelines-*,modernize-*,readability-*
# Exclude: -*performance-*,-*misc-const-correctness

---
Checks: >-
  bugprone-*,
  cppcoreguidelines-*,
  modernize-*,
  readability-*,
  -bugprone-easily-copyable-unique-ptr,
  -cppcoreguidelines-avoid-magic-numbers,
  -cppcoreguidelines-pro-bounds-array-to-pointer-decay,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -cppcoreguidelines-init-variables,
  -cppcoreguidelines-missing-std-forward,
  -cppcoreguidelines-pro-type-member-init,
  -cppcoreguidelines-avoid-c-arrays,
  -cppcoreguidelines-special-member-functions,
  -cppcoreguidelines-explicit-virtual-functions,
  -cppcoreguidelines-virtual-class-destructor,
  -cppcoreguidelines-owning-memory,
  -cppcoreguidelines-no-malloc,
  -cppcoreguidelines-avoid-reference-member-variable,
  -cppcoreguidelines-prefer-member-initializer,
  -cppcoreguidelines-pro-type-union-access,
  -cppcoreguidelines-pro-type-vararg,
  -cppcoreguidelines-pro-bounds-constant-array-index,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-avoid-capturing-*-capture,
  -cppcoreguidelines-rvalue-reference-param-not-moved,
  -cppcoreguidelines-c-copy-assignment-signature,
  -modernize-use-trailing-return-type,
  -modernize-use-nodiscard,
  -modernize-use-default-member-init,
  -modernize-use-override,
  -modernize-avoid-c-arrays,
  -modernize-use-auto,
  -readability-avoid-unconditional-preprocessor-if,
  -readability-convert-member-functions-to-static,
  -readability-identifier-naming,
  -readability-qualified-auto,
  -readability-magic-numbers,
  -readability-else-return,
  -readability-avoid-const-params-in-decls,
  -readability-non-const-parameter,
  -*performance-*,
  -*misc-const-correctness,
  -*misc-confusable-identifiers,
  -*misc-no-recursion,
HeaderFilterRegex: '.*\.(hpp|h|hxx|hh)$'

